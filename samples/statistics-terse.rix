## Statistics — Terse Syntax ##
## Uses {; } for MULTI and PRINT for output ##

Sum(acc, val) -> acc + val

Mean(list) -> (list |:> 0 >: Sum) / LEN(list)

Variance(list) -> {;
  avg := Mean(list);
  sqDiffs := list |>> (x) -> (x - avg) ^ 2;
  (sqDiffs |:> 0 >: Sum) / LEN(list)
}

data = [10, 20, 30, 40, 50, 60]

m = Mean(data);
v = Variance(data);
s = SQRT(v);

PRINT(
  "Data: " + data,
  "Mean: " + m,
  "Variance: " + v,
  "StdDev: " + s
)
